# ─── LegadoZero — Variables de Entorno ───────────────────────────
# Copia este archivo como .env.local para desarrollo local
# NUNCA subas .env.local al repositorio

# ── Supabase ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Service role (solo en backend/API — NUNCA en VITE_)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
SUPABASE_URL=https://tu-proyecto.supabase.co

# ── Lemon Squeezy (pagos internacionales + PPP) ───────────────────
# Crea un producto en lemonsqueezy.com y copia el checkout URL
VITE_LEMON_CHECKOUT_URL=https://legadozero.lemonsqueezy.com/buy/tu-product-id
LEMON_SQUEEZY_WEBHOOK_SECRET=tu_webhook_secret

# ── GLM-4 (Zhipu AI) ─────────────────────────────────────────────
# Regístrate en open.bigmodel.cn y genera una API key
VITE_GLM_API_KEY=tu_glm_api_key
GLM_API_KEY=tu_glm_api_key

# ── Resend (emails) ───────────────────────────────────────────────
RESEND_API_KEY=re_tu_api_key
RESEND_DOMAIN=legadozero.com

# ── Twilio (WhatsApp) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACtu_account_sid
TWILIO_AUTH_TOKEN=tu_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886  # Sandbox: +14155238886

# ── App ───────────────────────────────────────────────────────────
APP_URL=https://legadozero.com
VITE_DEMO_MODE=true   # Cambiar a false en producción

# ── Seguridad del Cron ────────────────────────────────────────────
CRON_SECRET=genera_un_string_aleatorio_de_64_chars
VITE_ADMIN_EMAILS=tu@email.com,otro@admin.com
